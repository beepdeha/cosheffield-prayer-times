rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone can READ content; only signed-in admins can WRITE.
    match /announcements/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /mosques/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /businesses/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
